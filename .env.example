# Google OAuth (Google Cloud Console -> EdgeChase Content Tool)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth / Auth.js
# Generate with: npx auth secret
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Database (Vercel Postgres or Supabase connection string)
DATABASE_URL=

# Google Drive folder to sync clips from (the ID in the folder's share URL)
DRIVE_FOLDER_ID=

# Optional: Gemini API for caption/hook-text suggestions and vision-based clip
# matching in the concept generator. Free-tier key (no credit card needed at
# signup, at least as of this writing): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Remotion Lambda rendering (siehe README für die Deployment-Schritte)
REMOTION_LAMBDA_FUNCTION_NAME=
REMOTION_SERVE_URL=
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
