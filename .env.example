# Google OAuth (Google Cloud Console -> EdgeChase Content Tool)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth / Auth.js
# Generate with: npx auth secret
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Database (Vercel Postgres or Supabase connection string)
DATABASE_URL=

# Google Drive folder to sync clips from (the ID in the folder's share URL)
DRIVE_FOLDER_ID=

# Optional: Gemini API for caption/hook-text suggestions and vision-based clip
# matching in the concept generator. Free-tier key (no credit card needed at
# signup, at least as of this writing): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Video-Rendering: löst einen GitHub-Actions-Workflow aus, der das FFmpeg-
# Rendering übernimmt (siehe README, Abschnitt "Video-Rendering einrichten").
RENDER_GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
# Beliebiger langer Zufallsstring, z.B. mit: openssl rand -hex 32
# Muss identisch auch als GitHub-Actions-Repository-Secret hinterlegt sein.
RENDER_CALLBACK_SECRET=
